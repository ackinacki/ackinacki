max_pool_connections: {{ QSERVER_MAX_POOL_CONNECTIONS }}
acquire_timeout_secs: {{ QSERVER_ACQUIRE_TIMEOUT_SECS }}
sqlite_query_timeout_secs: {{ QSERVER_SQLITE_QUERY_TIMEOUT_SECS }}
sqlite_mmap_size: {{ QSERVER_SQLITE_MMAP_SIZE }}
sqlite_cache_size: {{ QSERVER_SQLITE_CACHE_SIZE }}
max_attached_db: {{ QSERVER_MAX_ATTACHED_DB }}

# ----------------------------------------------------------------------------------------------------------------------

# Histogram bucket boundaries for the gql_query_duration metric (milliseconds).
# Measures end-to-end GraphQL query execution time.
# Changes require a restart to take effect.
query_duration_boundaries:
  - 5.0
  - 10.0
  - 25.0
  - 50.0
  - 100.0
  - 200.0
  - 300.0
  - 500.0
  - 1000.0
  - 2500.0
  - 5000.0
  - 10000.0
  - 30000.0
  - 60000.0

# Histogram bucket boundaries for the gql_sqlite_query_duration metric (milliseconds).
# Measures SQLite query execution time (from connection acquire to release).
# Changes require a restart to take effect.
sqlite_query_boundaries:
  - 1.0
  - 2.0
  - 5.0
  - 10.0
  - 25.0
  - 50.0
  - 100.0
  - 200.0
  - 300.0
  - 500.0
  - 1000.0
  - 2500.0
  - 5000.0
  - 10000.0
  - 30000.0
  - 60000.0
